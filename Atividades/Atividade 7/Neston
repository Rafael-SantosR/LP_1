public class Neston {

    public String sabor;
    public String cor;
    public int tamanho;


    public Neston (String sabor, String cor, int tamanho){
        this.sabor = sabor;
        this.cor = cor;
        this.tamanho = tamanho;

    }

    public String getSabor(){
        return sabor;
    }

    public void mudarSabor(String sabor){
        this.sabor = sabor;
        System.out.println("Sabor mudado");
    }


}
